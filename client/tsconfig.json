{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"  // <-- This is the key setting
  },
  "include": ["src", "postcss.config.cjs", "vite.config.ts", "tailwind.config.js", "tsconfig.app.json", "tsconfig.json", "tsconfig.node.json", "eslint.config.js"]
}
